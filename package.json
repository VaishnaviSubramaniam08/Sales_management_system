{
  "name": "consultancyproject",
  "version": "1.0.0",
  "main": "electron/main.js",
  "description": "",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\" \"electron .\"",
    "server": "node server/server.js",
    "client": "npm start --prefix client",
    "build-client": "npm run build --prefix client",
    "dist": "npm run build-client && electron-builder"
  },
  "build": {
    "appId": "com.inventory.app",
    "productName": "SmartInventory",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/build/**/*",
      "package.json",
      ".env"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsoncsv": "^0.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.5",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.17.2"
  }
}
